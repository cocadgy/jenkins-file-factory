pipeline {
    agent {
        label "jenkins_172.30.14.126"
    }

    stages {
        stage('代码检出') {
            steps {
                checkout scm   // 必须保留，否则Git元数据无法获取
            }
        }

        stage('强制失败测试') {
            steps {
                sh 'exit 1'
                // echo "测试通过"
                echo "GIT_COMMIT: ${env.GIT_COMMIT}"
            }
        }

        stage('运行 pytest 测试') {
            steps {
                echo "模拟 pytest 测试执行，生成 report.xml 和 report.html"
            }
        }
    }

    post {
    success {
        script {
            step([
                $class: "GitHubCommitStatusSetter",
                reposSource: [$class: "ManuallyEnteredRepositorySource", url: "https://github.com/cocadgy/dingofs-automation-framwork"],
                contextSource: [$class: "ManuallyEnteredCommitContextSource", context: "ci/jenkins/pytest"],
                // 关键修改：手动指定 commit SHA
                commitShaSource: [$class: "ManuallyEnteredShaSource", sha: env.GIT_COMMIT],
                // 暂时移除 errorHandlers，让真实错误浮现（构建失败而非 UNSTABLE）
                statusResultSource: [$class: "ConditionalStatusResultSource", results: [[$class: "AnyBuildResult", message: "所有 pytest 测试通过", state: "SUCCESS"]]]
            ])
        }
    }
    failure {
        script {
            step([
                $class: "GitHubCommitStatusSetter",
                reposSource: [$class: "ManuallyEnteredRepositorySource", url: "https://github.com/cocadgy/dingofs-automation-framwork"],
                contextSource: [$class: "ManuallyEnteredCommitContextSource", context: "ci/jenkins/pytest"],
                commitShaSource: [$class: "ManuallyEnteredShaSource", sha: env.GIT_COMMIT],
                statusResultSource: [$class: "ConditionalStatusResultSource", results: [[$class: "AnyBuildResult", message: "pytest 测试失败，请检查报告", state: "FAILURE"]]]
            ])
        }
    }
    aborted {
        script {
            step([
                $class: "GitHubCommitStatusSetter",
                reposSource: [$class: "ManuallyEnteredRepositorySource", url: "https://github.com/cocadgy/dingofs-automation-framwork"],
                contextSource: [$class: "ManuallyEnteredCommitContextSource", context: "ci/jenkins/pytest"],
                commitShaSource: [$class: "ManuallyEnteredShaSource", sha: env.GIT_COMMIT],
                statusResultSource: [$class: "ConditionalStatusResultSource", results: [[$class: "AnyBuildResult", message: "构建被取消", state: "PENDING"]]]
            ])
        }
    }
}
}